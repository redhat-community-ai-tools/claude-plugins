{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude Plugin Manifest",
  "type": "object",
  "required": ["name", "version", "description", "skills"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string",
      "minLength": 10
    },
    "author": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "repository": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string" }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "path", "description"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "path": {
            "type": "string",
            "pattern": "\\.md$"
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path", "description"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "path": {
            "type": "string",
            "pattern": "\\.md$"
          },
          "description": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path", "description"],
        "properties": {
          "name": { "type": "string" },
          "path": {
            "type": "string",
            "pattern": "\\.md$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "tools": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "required": { "type": "boolean" },
              "description": { "type": "string" },
              "installUrl": { "type": "string" }
            }
          }
        }
      }
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "claude_code": { "type": "string" }
      },
      "additionalProperties": { "type": "string" }
    },
    "license": { "type": "string" },
    "categories": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
